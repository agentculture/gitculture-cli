# Per-machine config for gitculture's skills (repo: agentculture/ghafi).
# Copy this to .claude/skills.local.yaml (git-ignored) and adjust for your
# environment. Skills read .claude/skills.local.yaml first, falling back to
# this example. Both files live in the .claude/ directory at the repo root.

# Sibling project paths checked during the pr-review alignment-delta step.
# Workspace-relative paths (../foo) are preferred. Skills skip entries
# that don't exist on disk, so commenting out missing ones isn't required.
sibling_projects:
  - ../afi-cli
  - ../cfafi
  - ../steward
